{
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/contact", "destination": "/api/contact" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/franchise-info", "destination": "/api/franchise-info" },
    { "source": "/api/learn", "destination": "/api/learn" },
    { "source": "/api/validate-franchise-price", "destination": "/api/validate-franchise-price" },
    { "source": "/api/chat-log", "destination": "/api/chat-log" },
    { "source": "/api/pexels/search", "destination": "/api/pexels/search" },
    { "source": "/api/videos/search", "destination": "/api/videos/search" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
