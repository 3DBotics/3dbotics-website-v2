{
  "buildCommand": "npm install --include=dev && npm run build:client",
  "outputDirectory": "dist/public",
  "installCommand": "npm install --include=dev",
  "framework": null,
  "routes": [
    { "src": "/api/contact", "dest": "/api/contact" },
    { "src": "/api/chat", "dest": "/api/chat" },
    { "src": "/api/franchise-info", "dest": "/api/franchise-info" },
    { "src": "/api/learn", "dest": "/api/learn" },
    { "src": "/api/validate-franchise-price", "dest": "/api/validate-franchise-price" },
    { "src": "/api/chat-log", "dest": "/api/chat-log" },
    { "src": "/api/pexels/search", "dest": "/api/pexels/search" },
    { "src": "/api/videos/search", "dest": "/api/videos/search" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/favicon.png", "dest": "/favicon.png" },
    { "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
